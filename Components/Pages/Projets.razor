@page "/projects"

<PageTitle>Projets</PageTitle>
<div class="decorated-page page-projects">
    <h1 class="page-title">Mes projets</h1>

    <div class="project-card">

        <div class="project-header">
            <div>
                <h2>🎮 Morpion – Godot C#</h2>
                <p class="project-date">Avril 2026</p>
            </div>
            <span class="project-badge">Projet personnel</span>
        </div>

        <p>
            Jeu du morpion développé en C# avec Godot.
            Implémentation de deux niveaux d’IA dont un algorithme Minimax.
        </p>

        <div class="tech-list">
            <span>C#</span>
            <span>Godot</span>
            <span>IA</span>
            <span>Minimax</span>
        </div>

        <ul>
            <li>IA heuristique (blocage, victoire, fourchettes)</li>
            <li>IA Minimax (imbattable)</li>
            <li>Architecture orientée objet</li>
            <li>Export Windows (.exe)</li>
        </ul>

        <div class="project-actions">
            <a class="btn-primary"
               href="https://github.com/fcaneh-jeux/morpion/releases/download/v1.0.0/morpion_v1.zip"
               target="_blank">
                Télécharger
            </a>

            <a class="btn-secondary"
               href="https://github.com/fcaneh-jeux/morpion"
               target="_blank">
                GitHub
            </a>
        </div>

    </div>
</div>